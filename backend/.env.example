# URUSAI backend environment template.
# Copy to backend/.env, fill in real values, NEVER commit.
#
# Multi-token: any LLM / search API key field accepts comma-separated values:
#   GEMINI_API_KEY=key1,key2,key3
# Settings layer parses into list[str]; provider client rotates round-robin
# with rate-limit fallback.
#
# === Required core ===

# Main LLM (Gemini 3.1 family) + Embedding 2 (gemini-embedding-2).
# Without this URUSAI cannot run auto-mode integrator / embedder.
GEMINI_API_KEY=

# === Backup LLMs (optional, used for fallback / cross-provider abstain) ===
# OpenAI key also unlocks text-embedding-3, Whisper API, and GPT vision.
# Anthropic key also unlocks Claude vision (image inputs in the Messages API).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
# Qwen LLM + Qwen-VL vision via DashScope.
DASHSCOPE_API_KEY=
# Cohere chat + Embed v3 + Rerank v3.5 in one key. The Cohere SDK reads
# CO_API_KEY natively; URUSAI keeps the COHERE_API_KEY name for consistency
# and passes the value to the client explicitly.
COHERE_API_KEY=
# Mistral LLM + Pixtral vision in one key.
MISTRAL_API_KEY=
# xAI Grok.
XAI_API_KEY=
# Together AI: cheap open-weight inference (Llama / Qwen / DeepSeek hosted).
TOGETHER_API_KEY=
# Fireworks AI: fast open-weight inference + hosted Llama-Vision.
FIREWORKS_API_KEY=
# OpenRouter: one key fans out to 100+ hosted models — rate-limit escape hatch.
OPENROUTER_API_KEY=

# === Embedding / reranker fallback ===
# Voyage AI: voyage-3-large / voyage-multilingual-2 embeddings + rerank-2.5.
# Cohere Embed v3 + Rerank v3.5 reuse COHERE_API_KEY above.
# Jina Embeddings + Jina Reranker reuse JINA_API_KEY below.
# OpenAI text-embedding-3 reuses OPENAI_API_KEY above.
VOYAGE_API_KEY=

# === Channel: ASR fallback (hosted, optional) ===
# OpenAI Whisper API also reachable via OPENAI_API_KEY above.
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
ELEVENLABS_API_KEY=
GLADIA_API_KEY=

# === Channel: VLM / OCR / diarization (HF gated models — needed for pyannote / PaddleOCR-VL) ===
# HuggingFace User Access Token. Picked up automatically by huggingface_hub /
# transformers / pyannote.audio when set as HF_TOKEN.
HF_TOKEN=

# === Optional: external search / fetch (escalator channel) ===
JINA_API_KEY=
EXA_API_KEY=
TAVILY_API_KEY=
# Brave Search: independent (non-Bing / non-Google) index. Brave's own examples
# use BRAVE_SEARCH_API_KEY as the env-var name.
BRAVE_SEARCH_API_KEY=
# Serper: cheap Google SERP proxy.
SERPER_API_KEY=
# Perplexity Sonar: web-grounded answer + citations in one call.
PERPLEXITY_API_KEY=

# === Infra: Postgres (urusai docker-compose default; host port 5433) ===
PG_HOST=127.0.0.1
PG_PORT=5433
PG_USER=urusai
PG_PASSWORD=urusai_dev_pw
PG_DATABASE=urusai

# === Infra: Milvus (urusai docker-compose default; gRPC host port 19531) ===
MILVUS_URI=http://127.0.0.1:19531
MILVUS_TOKEN=

# === Infra: PaddleOCR-VL llama-cpp-server (optional, only if OCR channel uses local backend) ===
PADDLEOCR_VL_BACKEND=llama-cpp-server
PADDLEOCR_VL_SERVER_URL=http://127.0.0.1:8111/v1

# === Runtime settings ===
RUN_EVENTS_RETENTION_HOURS=24
